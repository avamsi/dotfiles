{
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "extraKnownMarketplaces": {
    "marimo-pair": {
      "source": {
        "source": "github",
        "repo": "marimo-team/marimo-pair"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "gopls-lsp@claude-plugins-official": true,
    "marimo-pair@marimo-pair": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "42",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus[1m]"
  },
  "fastMode": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "say -v Bells Done!"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "- Review $ARGUMENTS\n- Commit existing changes iff they are standalone and mergeable\n- Do not make changes; only instruct the primary agent\n- Return {\"ok\": true} iff all user requests are addressed\n- Return {\"ok\": false, \"reason\": \"<missing requested work>\"} otherwise",
            "model": "sonnet[1m]",
            "statusMessage": "Nikeing..",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "includeGitInstructions": false,
  "model": "fable[1m]",
  "permissions": {
    "allow": [
      "Bash(cargo test *)",
      "Bash(go test *)",
      "Bash(jj *)",
      "Bash(uv run pytest *)",
      "Edit",
      "MultiEdit",
      "NotebookEdit",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "mcp__chrome-devtools"
    ],
    "defaultMode": "auto"
  },
  "preferredNotifChannel": "terminal_bell",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": ["github.com"]
    }
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "tui": "fullscreen"
}
